{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "Tu",
  "scopeName": "source.tu",
  "fileTypes": ["tu"],
  "patterns": [
    { "include": "#comment" },
    { "include": "#string" },
    { "include": "#template-string" },
    { "include": "#regex" },
    { "include": "#number" },
    { "include": "#style-block" },
    { "include": "#markdown-block" },
    { "include": "#keyword" },
    { "include": "#declaration-name" },
    { "include": "#constant" },
    { "include": "#type-primitive" },
    { "include": "#operator" },
    { "include": "#prop-key" },
    { "include": "#tag-call" },
    { "include": "#component-name" },
    { "include": "#identifier" }
  ],
  "repository": {
    "comment": {
      "patterns": [
        {
          "match": "//.*$",
          "name": "comment.line.double-slash.tu"
        }
      ]
    },
    "string": {
      "patterns": [
        {
          "name": "string.quoted.double.tu",
          "begin": "\"",
          "end": "\"",
          "patterns": [
            {
              "match": "\\\\(n|t|r|\"|\\\\)",
              "name": "constant.character.escape.tu"
            }
          ]
        },
        {
          "name": "string.quoted.single.tu",
          "begin": "'",
          "end": "'",
          "patterns": [
            {
              "match": "\\\\(n|t|r|'|\\\\)",
              "name": "constant.character.escape.tu"
            }
          ]
        }
      ]
    },
    "template-string": {
      "name": "string.template.tu",
      "begin": "`",
      "end": "`",
      "patterns": [
        {
          "match": "\\\\(`|\\$|n|t|r|\\\\)",
          "name": "constant.character.escape.tu"
        },
        {
          "begin": "\\$\\{",
          "beginCaptures": { "0": { "name": "punctuation.section.embedded.begin.tu" } },
          "end": "\\}",
          "endCaptures": { "0": { "name": "punctuation.section.embedded.end.tu" } },
          "patterns": [
            { "include": "$self" }
          ]
        }
      ]
    },
    "regex": {
      "patterns": [
        {
          "match": "(?x)(?<![\\w)\\]}])/(?:\\\\.|\\[(?:\\\\.|[^\\]\\\\])*\\]|[^/\\\\\\n])+/[dgimsuvy]*",
          "name": "string.regexp.tu"
        }
      ]
    },
    "number": {
      "patterns": [
        {
          "match": "\\b\\d+(\\.\\d+)?\\b",
          "name": "constant.numeric.tu"
        }
      ]
    },
    "keyword": {
      "patterns": [
        {
          "match": "\\b(let|export|default|import|from|as|interface|type|enum|Exception|if|else|for|of|in|where|order|by|take|skip|computed|effect|watch|server|client|stream|defer|async|await|try|catch|finally|throw|return|new|external|style|markdown)\\b",
          "name": "keyword.control.tu"
        }
      ]
    },
    "declaration-name": {
      "patterns": [
        {
          "match": "\\b(interface|type|enum|Exception)\\s+([A-Z_$][A-Za-z0-9_$]*)",
          "captures": {
            "1": { "name": "keyword.control.tu" },
            "2": { "name": "entity.name.type.tu" }
          }
        },
        {
          "match": "\\b(?:export\\s+)?(?:default\\s+)?let\\s+([A-Za-z_$][A-Za-z0-9_$]*)",
          "captures": {
            "1": { "name": "entity.name.function.tu" }
          }
        }
      ]
    },
    "constant": {
      "patterns": [
        {
          "match": "\\b(true|false|null)\\b",
          "name": "constant.language.tu"
        }
      ]
    },
    "type-primitive": {
      "patterns": [
        {
          "match": "\\b(string|number|boolean|any|unknown|void|never|null|undefined|object|bigint|symbol|Child|VNode|Event|Promise)\\b",
          "name": "support.type.primitive.tu"
        }
      ]
    },
    "operator": {
      "patterns": [
        {
          "match": "=>|\\*\\*=|\\*\\*|\\?\\?|\\?\\.|\\.\\.\\.|\\.\\.|&&|\\|\\||==|!=|<=|>=|<<|>>|[+\\-*/%=&|^~!<>?:]=?",
          "name": "keyword.operator.tu"
        }
      ]
    },
    "prop-key": {
      "patterns": [
        {
          "match": "\\b([a-zA-Z_][a-zA-Z0-9_-]*)(?=\\s*:)",
          "name": "entity.other.attribute-name.tu"
        }
      ]
    },
    "tag-call": {
      "patterns": [
        {
          "comment": "HTML-style lowercase tags in tag-call position: `div(`, `h1 {`, `button(onClick: …)`. Colored with the standard HTML tag scope.",
          "match": "\\b([a-z][a-zA-Z0-9-]*)\\b(?=\\s*[\\({])",
          "name": "entity.name.tag.tu"
        },
        {
          "comment": "Capitalized identifiers in tag-call position are user components (`Card(title: \"x\") { … }`, `Greeting({ name: 'World' })`). Use the JSX-style `support.class.component` scope so themes that distinguish components colorize them in line with `<Card />` in JSX.",
          "match": "\\b([A-Z][a-zA-Z0-9_]*)\\b(?=\\s*[\\({])",
          "name": "support.class.component.tu"
        }
      ]
    },
    "component-name": {
      "patterns": [
        {
          "comment": "Capitalized identifiers NOT in call position — bare references to components / functions (e.g. `onClick: dec` if `dec` were capitalized, or `Card` passed as a value). Tu's user-defined types are functions, not classes, so use the function scope rather than `entity.name.type` (which themes color like a class).",
          "match": "\\b[A-Z][a-zA-Z0-9_]*\\b",
          "name": "entity.name.function.tu"
        }
      ]
    },
    "identifier": {
      "patterns": [
        {
          "match": "\\b[a-z_$][a-zA-Z0-9_$]*\\b",
          "name": "variable.other.tu"
        }
      ]
    },
    "style-block": {
      "begin": "\\b(style)\\s*(\\{)",
      "beginCaptures": {
        "1": { "name": "keyword.control.tu" },
        "2": { "name": "punctuation.section.embedded.begin.tu" }
      },
      "end": "(\\})",
      "endCaptures": {
        "1": { "name": "punctuation.section.embedded.end.tu" }
      },
      "name": "meta.embedded.block.css.tu",
      "contentName": "source.css",
      "patterns": [
        { "include": "source.css" }
      ]
    },
    "markdown-block": {
      "begin": "\\b(markdown)\\s*(\\{)",
      "beginCaptures": {
        "1": { "name": "keyword.control.tu" },
        "2": { "name": "punctuation.section.embedded.begin.tu" }
      },
      "end": "(\\})",
      "endCaptures": {
        "1": { "name": "punctuation.section.embedded.end.tu" }
      },
      "name": "meta.embedded.block.markdown.tu",
      "contentName": "text.html.markdown",
      "patterns": [
        { "include": "text.html.markdown" }
      ]
    }
  }
}
