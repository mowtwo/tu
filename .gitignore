node_modules/
dist/
lib/
.turbo/
coverage/
*.log
*.tsbuildinfo
.DS_Store
.idea/
.env
.env.local

# Playwright MCP scratch — page/console snapshots from in-session browser tests
.playwright-mcp/

# tu-shu site build output (deployed via .github/workflows/deploy-docs.yml)
**/.tu-shu/

# VitePress site build output (legacy — VitePress was retired in alpha.6;
# kept here so a stray dist/ wouldn't be tracked if anyone re-runs it)
docs/.vitepress/dist/
docs/.vitepress/cache/

# M2 typecheck artifacts: per-example compiled .ts shadow + project tsconfig
examples/*/Clicker.ts
examples/*/Greeting.ts
examples/*/Counter.ts
examples/*/Todo.ts
examples/*/Card.ts
examples/*/Diff.ts
examples/*/Scoped.ts
examples/*/tsconfig.typecheck.json

# VS Code: keep shared settings, ignore user-specific
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
!.vscode/launch.json
