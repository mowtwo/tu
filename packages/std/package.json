{
  "name": "@tu-lang/std",
  "version": "0.1.0-alpha.8",
  "description": "Tu standard library — placeholder.",
  "keywords": [
    "tu",
    "tu-lang",
    "stdlib"
  ],
  "author": "mow2",
  "license": "MIT",
  "homepage": "https://mowtwo.github.io/tu/",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mowtwo/tu.git",
    "directory": "packages/std"
  },
  "bugs": {
    "url": "https://github.com/mowtwo/tu/issues"
  },
  "type": "module",
  "main": "./dist/index.js",
