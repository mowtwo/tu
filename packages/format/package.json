{
  "name": "@tu-lang/format",
  "version": "0.1.0-alpha.7",
  "description": "Tu formatter — Prettier plugin in M3, moves to a real dprint plugin in R4.",
  "keywords": [
    "tu",
    "tu-lang",
    "formatter",
    "prettier-plugin"
  ],
  "author": "mow2",
  "license": "MIT",
  "homepage": "https://mowtwo.github.io/tu/",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mowtwo/tu.git",
    "directory": "packages/format"
  },
  "bugs": {
    "url": "https://github.com/mowtwo/tu/issues"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "vitest run",
    "check": "tsc --noEmit -p tsconfig.json",
    "clean": "rm -rf dist *.tsbuildinfo"
  },
  "dependencies": {
    "@tu-lang/compiler": "workspace:*"
  },
  "publishConfig": {
    "access": "public"
  }
}
