{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "rootDir": ".tu-build",
    "outDir": "dist",
    "tsBuildInfoFile": "./dist/.dts.tsbuildinfo",
    "lib": ["ES2023", "DOM"],
    "emitDeclarationOnly": true,
    "noUncheckedIndexedAccess": false,
    "noUnusedLocals": false,
    "noUnusedParameters": false
  },
  "include": [".tu-build/index.ts"],
  "references": [{ "path": "../runtime" }, { "path": "../std" }]
}
