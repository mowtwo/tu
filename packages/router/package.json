{
  "name": "@tu-lang/router",
  "version": "0.1.0-alpha.8",
  "description": "Universal Tu router — route matching and SSR helpers for Tu apps.",
  "keywords": [
    "tu",
    "tu-lang",
    "router",
    "ssr"
  ],
  "author": "mow2",
  "license": "MIT",
  "homepage": "https://mowtwo.github.io/tu/",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mowtwo/tu.git",
    "directory": "packages/router"
  },
  "bugs": {
    "url": "https://github.com/mowtwo/tu/issues"
  },
  "type": "module",
  "main": "./dist/index.js",
