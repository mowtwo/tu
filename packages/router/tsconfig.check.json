{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "rootDir": ".tu-check",
    "tsBuildInfoFile": "./.tu-check/.tsbuildinfo",
    "lib": ["ES2023", "DOM"],
    "noEmit": true,
    "noUncheckedIndexedAccess": false,
    "noUnusedLocals": false,
    "noUnusedParameters": false
  },
  "include": [".tu-check/index.ts"],
  "references": [{ "path": "../runtime" }, { "path": "../std" }]
}
