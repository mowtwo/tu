{
  "name": "@tu-lang/runtime",
  "version": "0.1.0-alpha.8",
  "description": "Universal Tu runtime — Signal cells, vnode construction, SSR. Browser DOM half lives in @tu-lang/dom.",
  "keywords": [
    "tu",
    "tu-lang",
    "runtime",
    "reactive",
    "signals",
    "tc39-signals",
    "ssr"
  ],
  "author": "mow2",
  "license": "MIT",
  "homepage": "https://mowtwo.github.io/tu/",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mowtwo/tu.git",
    "directory": "packages/runtime"
  },
  "bugs": {
    "url": "https://github.com/mowtwo/tu/issues"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "vitest run",
    "check": "tsc --noEmit -p tsconfig.json",
    "clean": "rm -rf dist *.tsbuildinfo"
  },
  "dependencies": {
    "signal-polyfill": "^0.2.2"
  },
  "publishConfig": {
    "access": "public"
  }
}
