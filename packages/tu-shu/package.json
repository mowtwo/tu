{
  "name": "@tu-lang/tu-shu",
  "version": "0.1.0-alpha.8",
  "description": "tu-shu (图书) — Tu-native static site generator. Markdown-driven docs sites built on @tu-lang/runtime + renderPage.",
  "keywords": [
    "tu",
    "tu-lang",
    "ssg",
    "static-site-generator",
    "markdown",
    "docs",
    "vitepress-alternative"
  ],
  "author": "mow2",
  "license": "MIT",
  "homepage": "https://mowtwo.github.io/tu/",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mowtwo/tu.git",
    "directory": "packages/tu-shu"
  },
  "bugs": {
    "url": "https://github.com/mowtwo/tu/issues"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "tu-shu": "./dist/cli.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "echo 'no tests yet'",
    "check": "tsc --noEmit -p tsconfig.json",
    "clean": "rm -rf dist *.tsbuildinfo"
  },
  "dependencies": {
    "@tu-lang/compiler": "workspace:*",
    "@tu-lang/runtime": "workspace:*",
    "gray-matter": "^4.0.3",
    "markdown-it": "^14.1.0",
    "shiki": "^2.5.0"
  },
  "devDependencies": {
    "@types/markdown-it": "^14.1.2"
  },
  "publishConfig": {
    "access": "public"
  }
}
