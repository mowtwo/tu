{
  "name": "@tu-lang/compiler",
  "version": "0.1.0-alpha.7",
  "description": "Tu compiler — lexer, parser, type-mapper, codegen.",
  "keywords": [
    "tu",
    "tu-lang",
    "compiler",
    "parser",
    "codegen",
    "reactive",
    "signals"
  ],
  "author": "mow2",
  "license": "MIT",
  "homepage": "https://mowtwo.github.io/tu/",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mowtwo/tu.git",
    "directory": "packages/compiler"
  },
  "bugs": {
    "url": "https://github.com/mowtwo/tu/issues"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "vitest run",
    "check": "tsc --noEmit -p tsconfig.json",
    "clean": "rm -rf dist *.tsbuildinfo"
  },
  "dependencies": {
    "markdown-it": "^14.1.0"
  },
  "devDependencies": {
    "@tu-lang/runtime": "workspace:*",
    "@types/markdown-it": "^14.1.2",
    "jsdom": "^26.0.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
