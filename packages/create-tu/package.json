{
  "name": "create-tu",
  "version": "0.0.0",
  "description": "Scaffold a new Tu project. Used as `npm create tu` or `npx create-tu`.",
  "type": "module",
  "license": "MIT",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "create-tu": "./dist/index.js"
  },
  "files": ["dist", "templates", "README.md"],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "vitest run",
    "check": "tsc --noEmit -p tsconfig.json",
    "clean": "rm -rf dist *.tsbuildinfo"
  }
}
