{
  "name": "vscode-tu",
  "displayName": "Tu",
  "description": "Tu language support for VS Code — syntax highlighting and file association.",
  "version": "0.0.1",
  "private": true,
  "license": "MIT",
  "publisher": "mowtwo",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "contributes": {
    "languages": [
      {
        "id": "tu",
        "aliases": [
          "Tu",
          "tu",
          "图"
        ],
        "extensions": [
          ".tu"
        ],
        "configuration": "./language-configuration.json",
        "icon": {
          "light": "./icons/tu-mono.svg",
          "dark": "./icons/tu-mono.svg"
        }
      }
    ],
    "grammars": [
      {
        "language": "tu",
        "scopeName": "source.tu",
        "path": "./syntaxes/tu.tmLanguage.json",
        "embeddedLanguages": {
          "meta.embedded.block.css.tu": "css",
          "meta.embedded.block.markdown.tu": "markdown"
        }
      }
    ]
  },
  "main": "./dist/index.js",
  "activationEvents": [
    "onLanguage:tu"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "vitest run",
    "check": "tsc --noEmit -p tsconfig.json",
    "clean": "rm -rf dist *.tsbuildinfo",
    "dev:install": "node scripts/install-dev.mjs",
    "dev:uninstall": "node scripts/install-dev.mjs --uninstall"
  },
  "dependencies": {
    "@tu-lang/lsp": "workspace:*",
    "vscode-languageclient": "^9.0.1"
  },
  "devDependencies": {
    "@types/vscode": "^1.85.0"
  }
}
