{
  "name": "vscode-tu",
  "displayName": "Tu",
  "description": "Tu language support for VS Code — syntax highlighting and file association.",
  "version": "0.0.0",
  "private": true,
  "license": "MIT",
  "publisher": "mowtwo",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": ["Programming Languages"],
  "contributes": {
    "languages": [
      {
        "id": "tu",
        "aliases": ["Tu", "tu", "图"],
        "extensions": [".tu"],
        "configuration": "./language-configuration.json",
        "icon": {
          "light": "./icons/tu.svg",
          "dark": "./icons/tu.svg"
        }
      }
    ],
    "grammars": [
      {
        "language": "tu",
        "scopeName": "source.tu",
        "path": "./syntaxes/tu.tmLanguage.json"
      }
    ]
  },
  "scripts": {
    "build": "echo 'vscode-tu is declarative-only; nothing to build'",
    "test": "vitest run",
    "check": "tsc --noEmit -p tsconfig.json",
    "clean": "rm -rf dist *.tsbuildinfo",
    "dev:install": "node scripts/install-dev.mjs",
    "dev:uninstall": "node scripts/install-dev.mjs --uninstall"
  }
}
