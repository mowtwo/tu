{
  "name": "@tu-lang/dom",
  "version": "0.1.0-alpha.8",
  "description": "Browser-only Tu runtime — mount/hydrate/defineCustomElement plus typed re-exports of DOM globals (`document`, `Event`, `HTMLElement`, …). Importing from this package is the explicit opt-in to the DOM platform.",
  "keywords": [
    "tu",
    "tu-lang",
    "runtime",
    "dom",
    "mount",
    "hydrate",
    "custom-elements"
  ],
  "author": "mow2",
  "license": "MIT",
  "homepage": "https://mowtwo.github.io/tu/",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mowtwo/tu.git",
    "directory": "packages/dom"
  },
  "bugs": {
    "url": "https://github.com/mowtwo/tu/issues"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "vitest run",
    "check": "tsc --noEmit -p tsconfig.json",
    "clean": "rm -rf dist *.tsbuildinfo"
  },
  "dependencies": {
    "@tu-lang/runtime": "workspace:*"
  },
  "devDependencies": {
    "@types/jsdom": "^28.0.1",
    "jsdom": "^29.1.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
